@tailwind base;
@tailwind components;
@tailwind utilities;

/* Scrollbar styling */
::-webkit-scrollbar {
  width: 8px;
  height: 8px;
}

::-webkit-scrollbar-track {
  background: #f1f5f9;
}

::-webkit-scrollbar-thumb {
  background: #cbd5e1;
  border-radius: 4px;
}

::-webkit-scrollbar-thumb:hover {
  background: #94a3b8;
}

/* Focus ring customization */
:focus-visible {
  @apply outline-none ring-2 ring-blue-500 ring-offset-2;
}

/* Smooth transitions */
* {
  @apply transition-colors duration-200;
}

/* Base body styling */
body {
  @apply bg-white text-slate-900;
}

/* Link styling */
a {
  @apply text-blue-600 hover:text-blue-700 underline;
}

button {
  @apply focus-visible:outline-none;
}

/* Input styling */
input,
textarea,
select {
  @apply border border-slate-200 rounded-md px-3 py-2 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500;
}

/* Code block styling */
code {
  @apply bg-slate-100 px-1.5 py-0.5 rounded text-sm font-mono;
}

pre {
  @apply bg-slate-900 text-slate-100 p-4 rounded-lg overflow-auto;
}
